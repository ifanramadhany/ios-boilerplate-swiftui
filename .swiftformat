--swiftversion 5.0
--indent 4
--linebreaks lf
--maxwidth 120
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--closingparen balanced
--commas inline
--semicolons inline
--trimwhitespace always
--insertlines enabled
--removelines enabled
--stripunusedargs closure-only
--self remove
--importgrouping testable-bottom
--ifdef no-indent
--patternlet hoist
--ranges no-space
--decimalgrouping none
--binarygrouping none
--octalgrouping none
--hexgrouping none
--exclude IOSBoilerplate/Resources
--exclude .build
--exclude DerivedData
--exclude Pods
--exclude Carthage
